{
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://unpkg.com; connect-src 'self' https://pkhftlbacapcarwnrhzn.supabase.co; frame-ancestors 'none'; form-action 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/metasbank-login.html" },
    { "source": "/login/", "destination": "/metasbank-login.html" },
    { "source": "/dashboard", "destination": "/metasbank-member.html" },
    { "source": "/dashboard/", "destination": "/metasbank-member.html" },
    { "source": "/member", "destination": "/metasbank-member.html" },
    { "source": "/member/", "destination": "/metasbank-member.html" },
    { "source": "/admin", "destination": "/metasbank-admin.html" },
    { "source": "/admin/", "destination": "/metasbank-admin.html" },
    { "source": "/agent", "destination": "/metasbank-agent.html" },
    { "source": "/agent/", "destination": "/metasbank-agent.html" },
    { "source": "/signup", "destination": "/metasbank-signup.html" },
    { "source": "/signup/", "destination": "/metasbank-signup.html" },
    { "source": "/admin/login.html", "destination": "/metasbank-admin-login.html" }
  ]
}
